# Used by the event RSVP form. Do not commit private Formspree IDs.
NEXT_PUBLIC_FORMSPREE_EVENT_ENDPOINT=

# Main research survey storage. Use "local" for development and
# "sharepoint-list" in production once Central has approved the app registration.
SURVEY_STORAGE_PROVIDER=local
SURVEY_STORAGE_WEBHOOK_URL=
SURVEY_STORAGE_WEBHOOK_SECRET=

# Microsoft Graph / SharePoint List storage. These must stay server-only.
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_LIST_ID=

# Optional JSON object for custom SharePoint internal column names.
# Example: {"submissionId":"CrashOutSubmissionId","answersJson":"Answers"}
SURVEY_SHAREPOINT_COLUMN_MAP=
